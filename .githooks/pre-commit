#!/bin/bash
# Block commits where problem files have a non-stub solve() method.
# Skip with: git commit --no-verify

staged_files=$(git diff --cached --name-only -- '*/problems/*.py')
if [ -z "$staged_files" ]; then
    exit 0
fi

for f in $staged_files; do
    # Check if solve() contains raise NotImplementedError and nothing else (just a docstring allowed)
    # Allow solve() that ONLY has raise NotImplementedError (+ optional docstring/return)
    if grep -q 'def solve' "$f" && ! grep -A20 'def solve' "$f" | grep -q 'raise NotImplementedError'; then
        echo "BLOCKED: $f"
        echo "  Problem file has a working solve(). Use --no-verify to override."
        exit 1
    fi
done

exit 0
